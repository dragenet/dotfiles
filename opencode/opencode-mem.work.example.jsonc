// opencode-mem config for personal machines.
// Copy to opencode-mem.jsonc (gitignored, per-machine) and adjust as needed.
// Full commented reference: the plugin writes a complete template to this
// path on first startup if it does not already exist.
{
  "storagePath": "~/.opencode-mem/data",
  "embeddingModel": "Xenova/nomic-embed-text-v1",

  "memory": {
    "defaultScope": "project"
  },

  "webServerEnabled": true,
  "webServerPort": 4747,

  "autoCaptureEnabled": true,
  "autoCaptureLanguage": "auto",

  // Work machines use kilo as the NDA-safe default provider (see
  // docs/model-selection.md). DeepSeek V4 Flash is an explicit cheap
  // structured-extraction pin — not inherited from the session model —
  // so memory capture stays predictable and low-cost.
  "opencodeProvider": "kilo",
  "opencodeModel": "deepseek/deepseek-v4-flash",

  "showAutoCaptureToasts": true,
  "showUserProfileToasts": true,
  "showErrorToasts": true,

  "userProfileAnalysisInterval": 10,
  "maxMemories": 10,

  "compaction": {
    "enabled": true,
    "memoryLimit": 10
  },
  "chatMessage": {
    "enabled": true,
    "maxMemories": 3,
    "excludeCurrentSession": true,
    "injectOn": "first"
  }
}
