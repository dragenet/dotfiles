  "mcp": {
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{file:secrets/context7.key}"
      },
      "enabled": true
    },
    "github": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "enabled": false,
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{file:secrets/github.pat}"
      }
    },
    "pdf-reader": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@sylphx/pdf-reader-mcp"
      ],
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true
    },
    "dart-mcp-server": {
      "type": "local",
      "command": [
        "dart",
        "mcp-server"
      ],
      "enabled": false,
      "environment": {}
    },
    "homeassistant": {
      "type": "remote",
      "url": "{file:secrets/homeassistant.url}",
      "enabled": true,
      "oauth": false,
      "headers": {
        "Authorization": "Bearer {file:secrets/homeassistant.token}"
      }
    },
    "firecrawl": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "firecrawl-mcp"
      ],
      "enabled": true,
      "environment": {
        "FIRECRAWL_API_URL": "{file:secrets/firecrawl.url}",
        "FIRECRAWL_API_KEY": "{file:secrets/firecrawl.key}"
      }
    },
    "jira": {
      "type": "local",
      "command": [
        "mcp-atlassian",
        "--jira-url",
        "{file:secrets/jira.url}",
        "--jira-personal-token",
        "{file:secrets/jira.token}"
      ],
      "enabled": true
    },
    "stitch": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@_davideast/stitch-mcp",
        "proxy"
      ],
      "environment": {
        "STITCH_API_KEY": "{file:secrets/stitch.key}"
      },
      "enabled": true
    }
  }
}
