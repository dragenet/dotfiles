{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "docs/global-rules.md",
    "docs/memory-rules.md"
  ],
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 10000
  },
  "plugin": [
    "opencode-mnemosyne",
    "opencode-anthropic-oauth"
  ],
  "permission": {
    "edit": "ask",
    "task": {
      "autopilot": "deny"
    },
    "bash": {
      "*": "ask",
      "cat *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "wc *": "allow",
      "pwd": "allow",
      "pwd *": "allow",
      "find . *": "allow",
      "find ./ *": "allow",
      "head *": "allow",
      "sort *": "allow",
      "ls *": "allow",
      "git log *": "allow",
      "tail *": "allow",
      "jq *": "allow",
      "yq *": "allow",
      "git status *": "allow",
      "git diff *": "allow",
      "git branch *": "allow",
      "npx ctx7*": "allow",
      "ctx7*": "allow",
      "rm -rf*": "deny",
      "dd *": "deny",
      "mkfs*": "deny",
      "reboot*": "deny",
      "shutdown*": "deny",
      "poweroff*": "deny",
      "git push --force*": "deny",
      "terraform destroy*": "deny"
    },
    "read": {
      "*": "allow"
    },
    "external_directory": {
      "*": "ask",
      "~/.config/opencode/**": "allow",
      "~/.dotfiles/opencode/**": "allow"
    }
  },
  "tools": {
    "playwright_*": false,
    "homeassistant_*": false,
    "chrome-devtools_*": false,
    "firecrawl_*": false,
    "jira_*": false,
    "stitch_*": false,
    "webfetch": false,
    "WebFetch": false
  },
  "agent": {
    "plan": {
      "prompt": "You are in PLAN MODE. Analyze the codebase thoroughly before making any changes. Do not execute any commands or write files. Only provide detailed analysis and plan.",
      "steps": 15,
      "tools": {
        "bash": false,
        "edit": false,
        "write": false
      },
      "permission": {
        "skill": {
          "*": "deny",
          "using-superpowers": "allow",
          "brainstorming": "allow",
          "writing-plans": "allow"
        }
      }
    },
    "autopilot": {
      "mode": "primary",
      "permission": {
        "bash": "deny",
        "edit": {
          "*": "deny",
          "docs/superpowers/**": "allow"
        },
        "task": {
          "*": "allow",
          "autopilot": "deny"
        },
        "skill": {
          "*": "deny",
          "using-superpowers": "allow",
          "autonomous-execution": "allow",
          "writing-plans": "allow",
          "subagent-driven-development": "allow",
          "dispatching-parallel-agents": "allow",
          "verification-before-completion": "allow",
          "requesting-code-review": "allow"
        }
      }
    },
    "coder": {
      "permission": {
        "task": {
          "*": "allow",
          "autopilot": "deny"
        },
        "skill": {
          "*": "deny",
          "using-superpowers": "allow",
          "brainstorming": "allow",
          "writing-plans": "allow",
          "executing-plans": "allow",
          "subagent-driven-development": "allow",
          "dispatching-parallel-agents": "allow",
          "test-driven-development": "allow",
          "systematic-debugging": "allow",
          "verification-before-completion": "allow",
          "requesting-code-review": "allow",
          "receiving-code-review": "allow",
          "using-git-worktrees": "allow",
          "finishing-a-development-branch": "allow",
          "claude-api": "allow",
          "webapp-testing": "allow"
        }
      }
    },
    "general": {
      "permission": {
        "task": {
          "*": "allow",
          "autopilot": "deny"
        },
        "skill": {
          "*": "deny",
          "using-superpowers": "allow",
          "brainstorming": "allow",
          "writing-plans": "allow",
          "executing-plans": "allow",
          "subagent-driven-development": "allow",
          "dispatching-parallel-agents": "allow",
          "test-driven-development": "allow",
          "systematic-debugging": "allow",
