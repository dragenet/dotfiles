        "firecrawl_firecrawl_monitor_run": true,
        "firecrawl_firecrawl_monitor_checks": true,
        "firecrawl_firecrawl_monitor_check": true
      },
      "permission": {
        "bash": "deny",
        "task": {
          "*": "allow",
          "autopilot": "deny"
        },
        "skill": {
          "*": "deny"
        }
      }
    },
    "cloudflare": {
      "permission": {
        "task": {
          "*": "allow",
          "autopilot": "deny"
        },
        "skill": {
          "*": "deny",
          "using-superpowers": "allow",
